    {
      "name": "01 - Happy Path",
      "item": [
        {
          "name": "TC_001 - Valid Transfer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ==============================================\r",
                  "// TC_001: Valid Transfer - All Fields\r",
                  "// Priority: P0 | Category: Happy Path\r",
                  "// ==============================================\r",
                  "\r",
                  "pm.test(\"Returns 201 Created\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has transfer_id (non-empty string)\", function () {\r",
                  "    var r = pm.response.json();\r",
                  "    pm.expect(r.transfer_id).to.be.a(\"string\");\r",
                  "    pm.expect(r.transfer_id.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Status is valid enum: pending, completed, or failed\", function () {\r",
                  "    var r = pm.response.json();\r",
                  "    pm.expect(r.status).to.be.oneOf([\"pending\", \"completed\", \"failed\"]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Exchange rate is a positive number\", function () {\r",
                  "    var r = pm.response.json();\r",
                  "    pm.expect(r.exchange_rate).to.be.a(\"number\");\r",
                  "    pm.expect(r.exchange_rate).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Fees is a non-negative number\", function () {\r",
                  "    var r = pm.response.json();\r",
                  "    pm.expect(r.fees).to.be.a(\"number\");\r",
                  "    pm.expect(r.fees).to.be.at.least(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Estimated completion is valid datetime\", function () {\r",
                  "    var r = pm.response.json();\r",
                  "    var d = new Date(r.estimated_completion);\r",
                  "    pm.expect(d.toString()).to.not.equal(\"Invalid Date\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has ALL 5 required fields\", function () {\r",
                  "    pm.expect(pm.response.json()).to.have.all.keys(\r",
                  "        \"transfer_id\", \"status\", \"exchange_rate\",\r",
                  "        \"fees\", \"estimated_completion\"\r",
                  "    );\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type header is application/json\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                  "      .to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time under 2 seconds\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
